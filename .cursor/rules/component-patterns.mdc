## File Drop Context Pattern

Global drag-drop handling with processing state:

```tsx
import { FileDropProvider, useFileDrop, type WorkbenchItem } from '@/context/FileDropContext'

// In component
const {
  isDragging,
  setIsDragging,
  processingFiles,
  addProcessingFile,
  workbenchItems,
  hasNewItem,
  clearNewItemFlag,
} = useFileDrop()

// ProcessingFile type
interface ProcessingFile {
  id: string
  name: string
  progress: number
  status: 'uploading' | 'processing' | 'complete' | 'error'
}
```
