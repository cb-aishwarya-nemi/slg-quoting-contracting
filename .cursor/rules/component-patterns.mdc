## Navigation Context Pattern

App-level navigation without React Router:

```tsx
import { NavigationProvider, useNavigation } from '@/context/NavigationContext'

// Wrap app
<NavigationProvider>
  <AppLayout>
    <PageRouter />
  </AppLayout>
</NavigationProvider>

// Use in components
function PageRouter() {
  const { view, goToWorkbench, goToCustomer360, goToInvoiceDetails, goToAllInvoices } = useNavigation()
  
  if (view.name === 'customer360') return <Customer360Page />
  if (view.name === 'invoiceDetails') return <InvoiceDetailsPage />
  if (view.name === 'allInvoices') return <AllInvoicesPage />
  return <WorkbenchPage />
}

// View types
type View =
  | { name: 'workbench' }
  | { name: 'customer360'; customerId: string }
  | { name: 'invoiceDetails'; invoiceId: string }
  | { name: 'allInvoices'; customerId: string }

// Navigation flow
// Workbench → Customer360 → InvoiceDetails → AllInvoices
//     ↑_____________________________________________|
```

