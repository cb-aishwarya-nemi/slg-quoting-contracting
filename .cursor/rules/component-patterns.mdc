### Metrics Row (no borders, vertical separators)

```tsx
function MetricsRow({ metrics }) {
  return (
    <div className="flex">
      {metrics.map((metric, idx) => (
        <div key={idx} className="flex flex-1 items-start">
          <div className="flex-1 py-3">
            <div className="text-[11px] font-medium uppercase tracking-wider text-brand-fog">{metric.label}</div>
            <div className="mt-1 text-[15px] font-semibold text-brand-navy">{metric.value}</div>
          </div>
          {idx < metrics.length - 1 && (
            <div className="mx-4 h-12 w-px self-center bg-neutral-200" />
          )}
        </div>
      ))}
    </div>
  )
}
```

